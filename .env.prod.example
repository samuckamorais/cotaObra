# ============================================================================
# CotaObra — .env de PRODUÇÃO (VPS Hostinger compartilhada com FarmFlow)
# ----------------------------------------------------------------------------
# Copie para `.env` na raiz e ajuste. O script scripts/vps-setup-cotaobra.sh
# gera os segredos e preenche os valores detectados automaticamente.
#
# Os nomes abaixo são EXATAMENTE os que backend/src/config/env.ts lê.
# (Não use FIELD_ENCRYPTION_KEY / S3_* / CORS_ORIGINS — esses são do .env de
#  dev antigo e NÃO são lidos pelo backend.)
# ============================================================================

# ----------------------------------------------------------------------------
# [DEPLOY] Traefik compartilhado — detectado pelo script
# ----------------------------------------------------------------------------
# O compose usa a rede DEFAULT do projeto (cotaobra_default). Se o Traefik
# existente estiver em network_mode=bridge, o script o conecta a essa rede
# pós-up. Se estiver em host mode (padrão Hostinger), ele já alcança nossos
# containers pelo IP do bridge — nenhuma ação extra é necessária.

# Entrypoint HTTPS do Traefik (geralmente websecure).
TRAEFIK_ENTRYPOINT=websecure
# Nome do certresolver Let's Encrypt configurado no Traefik (ex: letsencrypt, le, myresolver).
TRAEFIK_CERTRESOLVER=letsencrypt

# Domínios (apontar DNS A → IP da VPS antes do go-live).
APP_DOMAIN=app.cotaobra.com.br
STORAGE_DOMAIN=storage.cotaobra.com.br

# ----------------------------------------------------------------------------
# [DEPLOY] Credenciais dos containers próprios (geradas pelo script)
# ----------------------------------------------------------------------------
POSTGRES_PASSWORD=
MINIO_ROOT_USER=cotaobra
MINIO_ROOT_PASSWORD=

# ============================================================================
# APP — variáveis lidas pelo backend (env.ts)
# ============================================================================
NODE_ENV=production
LOG_LEVEL=info

# Auth / cripto (geradas pelo script; 32+ chars cada)
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# CORS / URLs públicas
ALLOWED_ORIGINS=https://app.cotaobra.com.br
FRONTEND_URL=https://app.cotaobra.com.br
# Webhook público do backend (Evolution/Asaas/ERP batem aqui via nginx /api)
WEBHOOK_URL=https://app.cotaobra.com.br

# ----------------------------------------------------------------------------
# WhatsApp — Evolution API (instância dedicada na Evolution existente)
# ----------------------------------------------------------------------------
WHATSAPP_PROVIDER=evolution
# Preenchido pelo script: aponta para o container Evolution já rodando.
EVOLUTION_API_URL=
# A MESMA AUTHENTICATION_API_KEY da Evolution existente (peça/cole aqui).
EVOLUTION_API_KEY=
# Instância nova e exclusiva do CotaObra (não colide com as do FarmFlow).
EVOLUTION_INSTANCE_NAME=cotaobra
EVOLUTION_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# OpenAI (NLU + transcrição de áudio) — opcional, mas recomendado
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------------------------
# Billing — Asaas (sandbox para piloto)
# ----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ----------------------------------------------------------------------------
# Observabilidade — opcionais
# ----------------------------------------------------------------------------
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
APP_VERSION=1.0.0-pilot
GIT_SHA=

# ----------------------------------------------------------------------------
# E-mail (SMTP) — opcional
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=naoresponda@cotaobra.com.br

# CotaObra — Backend .env.example (dev local)
# Copie para `backend/.env` no repositório cotaobra e ajuste valores marcados como TODO.
# Versão: 1.0 — 18/05/2026

# ============================================================
# AMBIENTE
# ============================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================
# DATABASE & CACHE (apontam para docker-compose.dev.yml)
# ============================================================
DATABASE_URL="postgresql://cotaobra:cotaobra@localhost:5433/cotaobra_dev?schema=public"
REDIS_URL="redis://localhost:6380"

# ============================================================
# AUTH / SECURITY
# ============================================================
JWT_SECRET="dev-secret-change-me-32-chars-minimum-required"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="90d"
FIELD_ENCRYPTION_KEY="dev-aes256-key-32-bytes-must-have"   # 32 bytes para AES-256-GCM

# Rate limit base (override por endpoint em código)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# WHATSAPP — Evolution API (provider primário do MVP)
# ============================================================
WHATSAPP_PROVIDER=evolution                            # evolution | twilio | meta (somente evolution no MVP)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=local-dev-key-change-me              # bate com docker-compose.dev.yml
EVOLUTION_INSTANCE_NAME=cotaobra-dev                   # criar via Manager UI: http://localhost:8080/manager
EVOLUTION_WEBHOOK_SECRET="dev-webhook-secret"          # verifica assinatura

# Rate limit do Evolution (mitigação AUD-04 — números novos)
EVOLUTION_MAX_MSG_PER_HOUR=30                          # primeiros 14 dias após warming
EVOLUTION_MIN_DELAY_MS=8000                            # 8s entre mensagens
EVOLUTION_MAX_DELAY_MS=25000                           # 25s entre mensagens (randômico no range)
EVOLUTION_ABORT_AFTER_ERRORS=3                         # pausa 1h se 3 erros 5xx consecutivos

# Templates HSM (não usados com Evolution, mas mantém placeholder para futuro provider Meta)
# WHATSAPP_HSM_NAMESPACE=
# WHATSAPP_HSM_TEMPLATES={}

# ============================================================
# OPENAI (NLU + transcrição áudio)
# ============================================================
OPENAI_API_KEY="sk-TODO-pegar-com-tech-lead"
OPENAI_MODEL_NLU="gpt-4o"
OPENAI_MODEL_TRANSCRIPTION="whisper-1"
OPENAI_TIMEOUT_MS=3000                                 # fallback regex se exceder

# ============================================================
# STORAGE — MinIO (S3-compatible)
# ============================================================
STORAGE_PROVIDER=minio                                 # minio | s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin-dev
S3_BUCKET_PURCHASE_ORDERS=cotaobra-purchase-orders
S3_BUCKET_UPLOADS=cotaobra-uploads
S3_USE_PATH_STYLE=true                                 # MinIO requer path-style

# ============================================================
# EMAIL (Mailpit em dev, SES/Sendgrid em prod)
# ============================================================
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME="CotaObra (dev)"
EMAIL_FROM_ADDRESS="naoresponda@cotaobra.local"

# ============================================================
# BILLING — Asaas (sandbox no MVP)
# ============================================================
ASAAS_API_KEY="TODO-pegar-sandbox-key-no-asaas.com"
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET="dev-asaas-webhook-secret"

# ============================================================
# OBSERVABILIDADE
# ============================================================
SENTRY_DSN=""                                          # vazio em dev; setar em staging/prod
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

POSTHOG_API_KEY=""                                     # opcional em dev
POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# CORS / FRONTEND
# ============================================================
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
FRONTEND_URL="http://localhost:5173"
PUBLIC_FORM_URL="http://localhost:5173/r"              # link enviado ao engenheiro p/ multi-item
PROPOSAL_FORM_URL="http://localhost:5173/p"            # link enviado ao fornecedor

# ============================================================
# JOBS / CRONS
# ============================================================
BULL_QUEUE_PREFIX=cotaobra-dev
JOB_CONCURRENCY=2
ENABLE_CRONS=true

# ============================================================
# FEATURE FLAGS (defaults dev)
# ============================================================
FEATURE_AUDIO_TRANSCRIPTION=true
FEATURE_APPROVAL_WORKFLOW=true
FEATURE_ERP_WEBHOOK=false                              # só Sprint 8

# ============================================================
# WEBHOOK ERP (Sprint 8 — placeholder)
# ============================================================
# Configurado por tenant em runtime, não aqui.
ERP_WEBHOOK_HMAC_ALGO=sha256
ERP_WEBHOOK_TIMEOUT_MS=10000
ERP_WEBHOOK_MAX_RETRIES=5

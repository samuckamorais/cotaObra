# CotaObra — Frontend .env.example (dev local)
# Copie para `frontend/.env` no repositório cotaobra.
# Vite expõe variáveis prefixadas com VITE_ para o cliente.
# Versão: 1.0 — 18/05/2026

# ============================================================
# API
# ============================================================
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT_MS=15000

# ============================================================
# AUTH / SESSÃO
# ============================================================
VITE_TOKEN_STORAGE_KEY=cotaobra_token
VITE_REFRESH_TOKEN_STORAGE_KEY=cotaobra_refresh

# ============================================================
# OBSERVABILIDADE (frontend)
# ============================================================
VITE_SENTRY_DSN=""
VITE_SENTRY_ENVIRONMENT=development
VITE_POSTHOG_API_KEY=""
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# BRANDING
# ============================================================
VITE_APP_NAME="CotaObra"
VITE_APP_TAGLINE="Cotação de materiais de construção via WhatsApp"
VITE_SUPPORT_EMAIL="suporte@cotaobra.app"
VITE_SUPPORT_WHATSAPP="+5500000000000"                  # TODO: número de suporte

# ============================================================
# FEATURES (toggles UI)
# ============================================================
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_ONBOARDING_TOUR=true
VITE_FEATURE_DEBUG_PANEL=true                            # só dev

# ============================================================
# PWA (Sprint 7+)
# ============================================================
VITE_PWA_NAME=CotaObra
VITE_PWA_SHORT_NAME=CotaObra
VITE_PWA_THEME_COLOR="#0f172a"
VITE_PWA_BACKGROUND_COLOR="#ffffff"
